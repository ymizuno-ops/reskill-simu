# =================================================================
# .claudeignore
# Claude Code の探索対象から除外し、トークン消費を抑えるリスト
# =================================================================

# バージョン管理
.git/

# 仮想環境・依存関係
node_modules/
.venv/
venv/
env/

# ビルド成果物・キャッシュ
dist/
build/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# ML フレームワークのキャッシュ（大量のバイナリ・ログ）
catboost_info/

# 環境変数・機密情報
.env
.env.*
*.pem
credentials.json

# 大容量データ・静的アセット
data/raw/
data/processed/
data/master/
*.csv
*.tsv
*.xlsx
*.sqlite3
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.mp4
*.pdf

# ログ
*.log
logs/

# OS・エディタ
.DS_Store
.idea/
.vscode/
